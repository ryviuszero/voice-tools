{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "voice-tools",
  "compatibility_date": "2026-05-05",
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "21e4f19380de415c8a124ba8bc517649"
    }
  ]
}
