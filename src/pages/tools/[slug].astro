---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import BookmarkToggle from '../../components/BookmarkToggle.astro';
import TrafficOverview from '../../components/TrafficOverview.astro';
import GithubMetrics from '../../components/GithubMetrics.astro';
import ToolLogo from '../../components/ToolLogo.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import WorkflowToc from '../../components/WorkflowToc.astro';
import { changelogDescription, loadChangelog } from '../../lib/data-loader';
import { GISCUS, GISCUS_ENABLED, githubEditUrl } from '../../lib/site-config';
import {
  BADGE_LABEL, BADGE_CLASS, PRICING_LABEL,
  formatBeginnerFit, formatCategoryTagItems, formatPrice, formatQualityRisk, formatRightsConfidence, getAlternatives, visibleToolBadges,
} from '../../lib/tool-helpers';
import { localizedToolData } from '../../lib/i18n';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({ params: { slug: tool.slug }, props: { tool } }));
}

const { tool } = Astro.props;
const { data } = tool;
const { Content, headings } = await tool.render();

const allTools   = await getCollection('tools');
const changelog  = loadChangelog().filter((e) => e.tool_slug === tool.slug);
const alternativeTools = getAlternatives(tool, allTools);
const price      = formatPrice(tool);
const content    = localizedToolData(data, 'en');
const visibleBadges = visibleToolBadges(data.badges);
const categoryTags = formatCategoryTagItems(tool);
const editUrl = githubEditUrl(`src/content/tools/${tool.slug}.md`);

type TocItem = {
  href: string;
  label: string;
  children?: TocItem[];
};
type RenderedHeading = {
  depth: number;
  slug: string;
  text: string;
};
function buildGuideToc(renderedHeadings: ReadonlyArray<RenderedHeading>): TocItem[] {
  const items: TocItem[] = [];

  for (const heading of renderedHeadings) {
    if (heading.depth === 2) {
      items.push({ href: `#${heading.slug}`, label: heading.text, children: [] });
      continue;
    }

    if (heading.depth === 3 && items.length > 0) {
      items[items.length - 1].children?.push({ href: `#${heading.slug}`, label: heading.text });
    }
  }

  return items;
}

const guideTocItems = buildGuideToc(headings ?? []);
const tocItems = [
  {
    href: '#overview',
    label: 'Snapshot',
    children: [
      data.video && { href: '#tool-video', label: 'Video' },
      { href: '#licensing', label: 'Licensing' },
      content.gotchas.length > 0 && { href: '#gotchas', label: 'Usage notes' },
      { href: '#capabilities', label: 'Capabilities' },
      data.language_quality && Object.keys(data.language_quality).length > 0 && { href: '#language-quality', label: 'Language quality' },
      data.traffic_estimates && { href: '#traffic', label: 'Traffic' },
      data.github_metrics && { href: '#github', label: 'GitHub' },
      { href: '#pricing', label: 'Pricing' },
      data.portability && { href: '#lock-in', label: 'Lock-in risk' },
    ].filter(Boolean) as TocItem[],
  },
  { href: '#guide', label: 'Guide', children: guideTocItems },
  (alternativeTools.length > 0 || changelog.length > 0 || GISCUS_ENABLED) && {
    href: alternativeTools.length > 0 ? '#alternatives' : changelog.length > 0 ? '#changelog' : '#discussion',
    label: 'More',
    children: [
      alternativeTools.length > 0 && { href: '#alternatives', label: 'Alternatives' },
      changelog.length > 0 && { href: '#changelog', label: 'Recent changes' },
      GISCUS_ENABLED && { href: '#discussion', label: 'Discussion' },
    ].filter(Boolean) as TocItem[],
  },
].filter(Boolean) as TocItem[];

const QUALITY_DOT: Record<string, string> = {
  excellent: 'bg-green-500',
  good:      'bg-yellow-400',
  limited:   'bg-orange-400',
  poor:      'bg-red-400',
};
const QUALITY_LABEL: Record<string, string> = {
  excellent: 'Excellent',
  good:      'Good',
  limited:   'Limited',
  poor:      'Poor',
};
const LANG_NAME: Record<string, string> = {
  en: 'English', zh: 'Chinese', es: 'Spanish', fr: 'French',
  de: 'German',  pt: 'Portuguese', ja: 'Japanese', ko: 'Korean',
  ar: 'Arabic',  hi: 'Hindi', ru: 'Russian', it: 'Italian',
};

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: content.name,
  url: data.website,
  description: content.tagline,
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Web',
  offers: data.pricing.model === 'free' || data.pricing.model === 'open_source'
    ? { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
    : { '@type': 'Offer', url: data.pricing.pricing_url },
  featureList: [
    data.capabilities.voice_cloning    && 'Voice Cloning',
    data.capabilities.multilingual     && 'Multilingual',
    data.capabilities.chinese_support  && 'Chinese Language Support',
    data.capabilities.realtime_capable && 'Real-time Processing',
    data.capabilities.open_source      && 'Open Source',
  ].filter(Boolean),
};

const CHANGE_TYPE_LABEL: Record<string, string> = {
  pricing_change:  'Pricing Change',
  feature_added:   'Feature Added',
  product_change:  'Product Change',
  model_release:   'Model Release',
  policy_change:   'Policy Change',
};
---

<BaseLayout title={content.name} description={content.tagline}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <main class="mx-auto max-w-7xl px-4 py-12">
    <div class="grid gap-10 lg:grid-cols-[14rem_minmax(0,48rem)] xl:grid-cols-[16rem_minmax(0,48rem)] lg:justify-center">
      <aside class="hidden lg:block" data-pagefind-ignore>
        <WorkflowToc items={tocItems} label="On this page" ariaLabel="Tool contents" />
      </aside>

      <article class="min-w-0 space-y-12" data-pagefind-body>

    <!-- ① Top card -->
    <section id="overview" class="scroll-mt-24 flex flex-col sm:flex-row gap-6 items-start">
      <ToolLogo
        src={data.logo}
        alt={`${content.name} logo`}
        size={64}
        loading="eager"
        class="w-16 h-16 rounded-xl object-contain bg-gray-50 border border-gray-100 shrink-0 dark:bg-white/[0.06] dark:border-white/[0.08]"
      />
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-2 mb-1">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{content.name}</h1>
          {visibleBadges.map((badge) => (
            <span class={`text-xs px-2 py-0.5 rounded-full ${BADGE_CLASS[badge]}`}>
              {BADGE_LABEL[badge]}
            </span>
          ))}
        </div>
        <p class="text-gray-500 dark:text-slate-400 text-lg mb-4">{content.tagline}</p>
        <div class="flex flex-wrap items-center gap-3">
          <a href={data.website} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white rounded-lg text-sm font-medium hover:bg-gray-700 transition-colors dark:bg-[#818cf8] dark:hover:bg-[#6366f1] btn-neon btn-neon-voiceai">
            Visit Website ↗
          </a>
          <button
            class="compare-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium hover:border-gray-500 transition-colors dark:border-white/20 dark:text-slate-300 dark:hover:border-[#818cf8]/50 dark:hover:text-[#818cf8]"
            data-slug={tool.slug}
            data-name={content.name}
          >
            + Compare
          </button>
          <BookmarkToggle slug={tool.slug} size="detail" />
          <div class="flex basis-full flex-wrap items-center gap-2 pt-1">
            {categoryTags.map((item) => (
              <a
                href={`/category/${item.slug}/`}
                class="rounded-md border border-gray-300/70 bg-gray-100/70 px-2 py-0.5 text-xs font-semibold text-gray-700 transition-colors hover:border-gray-500 hover:bg-gray-200/70 dark:border-white/[0.08] dark:bg-white/[0.06] dark:text-slate-200 dark:hover:border-[#818cf8]/50 dark:hover:text-[#818cf8]"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ② Core metrics bar -->
    <section class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { label: 'Price',       value: price },
        { label: 'Quality Risk', value: formatQualityRisk(tool) },
        { label: 'Beginner Fit', value: formatBeginnerFit(tool) },
        { label: 'Rights', value: formatRightsConfidence(tool) },
      ].map(({ label, value }) => (
        <div class="bg-gray-50 dark:bg-white/[0.06] rounded-xl p-3 text-center">
          <div class="text-xs text-gray-400 dark:text-slate-500 mb-0.5">{label}</div>
          <div class="truncate text-sm font-semibold text-gray-900 dark:text-slate-100">{value}</div>
        </div>
      ))}
    </section>

    {data.video && (
      <YouTubeEmbed
        id="tool-video"
        url={data.video.url}
        title={data.video.title}
        heading="Demo"
        caption={data.video.title}
      />
    )}

    <!-- ③ Licensing — the "can I actually use this?" section -->
    <section id="licensing" class="scroll-mt-24">
      <h2 class="text-lg font-semibold mb-1 text-gray-900 dark:text-white">Use Cases</h2>
      <p class="text-sm text-gray-400 dark:text-slate-500 mb-4">Licensing and usage summary for common production scenarios</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          {
            label: 'Commercial Projects',
            sublabel: 'Use outputs in paid products or client work',
            ok: data.licensing.commercial_use,
          },
          {
            label: 'YouTube Monetization',
            sublabel: 'Monetize YouTube videos made with this tool',
            ok: data.licensing.youtube_monetization,
          },
          {
            label: 'Shipping in Games',
            sublabel: 'Bundle generated audio in a commercial game release',
            ok: data.licensing.game_use,
          },
          {
            label: 'Voice Cloning',
            sublabel: 'Clone a real person\'s voice (with their consent)',
            ok: data.licensing.voice_cloning_allowed,
          },
        ].map(({ label, sublabel, ok }) => (
          <div class={`flex items-start gap-3 rounded-xl p-4 border ${ok ? 'border-green-200 bg-green-50 dark:border-green-500/25 dark:bg-green-500/[0.08]' : 'border-red-100 bg-red-50 dark:border-red-500/25 dark:bg-red-500/[0.08]'}`}>
            <span class={`text-xl shrink-0 mt-0.5 ${ok ? 'text-green-600 dark:text-green-400' : 'text-red-400 dark:text-red-400'}`}>{ok ? '✅' : '✗'}</span>
            <div>
              <div class="text-sm font-semibold text-gray-800 dark:text-slate-100">{label}</div>
              <div class="text-xs text-gray-500 dark:text-slate-400 mt-0.5">{sublabel}</div>
            </div>
          </div>
        ))}
      </div>
      {content.licensingNotes && (
        <p class="mt-3 text-sm text-gray-500 dark:text-slate-400 bg-gray-50 dark:bg-white/[0.04] rounded-xl p-4 border border-gray-100 dark:border-white/[0.08]">{content.licensingNotes}</p>
      )}
    </section>

    <!-- ④ Gotchas — what they don't tell you -->
    {content.gotchas.length > 0 && (
      <section id="gotchas" class="scroll-mt-24">
        <h2 class="text-lg font-semibold mb-1 text-gray-900 dark:text-white">⚠️ Usage Notes</h2>
        <p class="text-sm text-gray-400 dark:text-slate-500 mb-4">Important constraints to review before production use</p>
        <ul class="space-y-2">
          {content.gotchas.map((gotcha: string) => (
            <li class="flex items-start gap-3 bg-amber-50 dark:bg-amber-500/[0.08] border border-amber-200 dark:border-amber-500/25 rounded-xl px-4 py-3">
              <span class="text-amber-500 dark:text-amber-400 shrink-0 mt-0.5">!</span>
              <span class="text-sm text-amber-900 dark:text-amber-200">{gotcha}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ⑤ Capabilities -->
    <section id="capabilities" class="scroll-mt-24">
      <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Capabilities</h2>
      <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm">
        {([
          { label: 'Voice Cloning',    ok: data.capabilities.voice_cloning },
          { label: 'Multilingual',     ok: data.capabilities.multilingual },
          { label: 'Real-time',        ok: data.capabilities.realtime_capable },
          { label: 'Open Source',      ok: data.capabilities.open_source },
          ...(data.capabilities.offline_capable !== undefined
            ? [{ label: 'Offline / Local', ok: data.capabilities.offline_capable }]
            : []),
          ...(data.capabilities.batch_api !== undefined
            ? [{ label: 'Batch API',     ok: data.capabilities.batch_api }]
            : []),
        ] as { label: string; ok: boolean }[]).map(({ label, ok }) => (
          <li class={`flex items-center gap-2 px-3 py-2 rounded-lg ${ok ? 'bg-green-50 text-green-800 dark:bg-green-500/[0.10] dark:text-green-300' : 'bg-gray-50 text-gray-400 dark:bg-white/[0.04] dark:text-slate-500'}`}>
            <span>{ok ? '✅' : '○'}</span>
            <span>{label}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- ⑥ Language quality (only shown if data exists) -->
    {data.language_quality && Object.keys(data.language_quality).length > 0 && (
      <section id="language-quality" class="scroll-mt-24">
        <h2 class="text-lg font-semibold mb-1 text-gray-900 dark:text-white">Language Quality</h2>
        <p class="text-sm text-gray-400 dark:text-slate-500 mb-4">Independent assessment — not just "supported languages"</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {Object.entries(data.language_quality).map(([code, tier]) => (
            <div class="flex items-center gap-2 bg-gray-50 dark:bg-white/[0.06] rounded-lg px-3 py-2">
              <span class={`w-2.5 h-2.5 rounded-full shrink-0 ${QUALITY_DOT[tier as string]}`}></span>
              <span class="text-sm font-medium text-gray-700 dark:text-slate-200">{LANG_NAME[code] ?? code}</span>
              <span class="text-xs text-gray-400 dark:text-slate-500 ml-auto">{QUALITY_LABEL[tier as string]}</span>
            </div>
          ))}
        </div>
        <div class="flex items-center gap-4 mt-3 text-xs text-gray-400 dark:text-slate-500">
          {(['excellent','good','limited','poor'] as const).map((t) => (
            <span class="flex items-center gap-1.5">
              <span class={`w-2 h-2 rounded-full ${QUALITY_DOT[t]}`}></span>
              {QUALITY_LABEL[t]}
            </span>
          ))}
        </div>
      </section>
    )}

    <!-- ⑦ Traffic estimates (only shown if data exists) -->
    {data.traffic_estimates && (
      <div id="traffic" class="scroll-mt-24">
        <TrafficOverview traffic={data.traffic_estimates} />
      </div>
    )}

    {data.github_metrics && (
      <div id="github" class="scroll-mt-24">
        <GithubMetrics metrics={data.github_metrics} />
      </div>
    )}

    <!-- ⑦ Pricing + cost estimator -->
    <section id="pricing" class="scroll-mt-24">
      <h2 class="text-lg font-semibold mb-3 text-gray-900 dark:text-white">Pricing</h2>
      <div class="flex items-center gap-4 mb-3">
        <span class="text-2xl font-bold text-gray-900 dark:text-white">{price}</span>
        <span class="text-sm text-gray-400 dark:text-slate-500 capitalize">{PRICING_LABEL[data.pricing.model]}</span>
        {data.pricing.has_free_tier && (
          <span class="text-xs px-2 py-0.5 bg-green-100 text-green-700 rounded-full dark:bg-green-500/15 dark:text-green-300">Free tier available</span>
        )}
      </div>
      <a href={data.pricing.pricing_url} target="_blank" rel="noopener noreferrer"
         class="text-sm text-blue-600 hover:underline dark:text-[#818cf8] dark:hover:text-[#a5b4fc]">
        View full pricing →
      </a>

      {/* Cost estimator — only shown when unit cost data is available */}
      {(data.pricing.cost_per_1000_chars || data.pricing.cost_per_minute) && (
        <div class="mt-5 bg-gray-50 dark:bg-white/[0.04] border border-gray-200 dark:border-white/[0.08] rounded-xl p-4" id="cost-estimator">
          <div class="text-sm font-semibold text-gray-700 dark:text-slate-300 mb-3">💰 Cost Estimator</div>
          {data.pricing.cost_per_1000_chars && (
            <div class="space-y-2">
              <label class="block text-xs text-gray-500 dark:text-slate-400">
                Monthly characters generated
                <input
                  type="number"
                  id="est-chars"
                  min="0"
                  placeholder="e.g. 500000"
                  class="mt-1 block w-full rounded-lg border border-gray-200 dark:border-white/[0.12] bg-white dark:bg-white/[0.06] text-gray-900 dark:text-slate-100 px-3 py-2 text-sm focus:border-gray-400 dark:focus:border-[#818cf8]/50 focus:outline-none"
                  data-rate={data.pricing.cost_per_1000_chars}
                  data-mode="chars"
                />
              </label>
            </div>
          )}
          {data.pricing.cost_per_minute && (
            <div class="space-y-2">
              <label class="block text-xs text-gray-500 dark:text-slate-400">
                Monthly call minutes
                <input
                  type="number"
                  id="est-minutes"
                  min="0"
                  placeholder="e.g. 1000"
                  class="mt-1 block w-full rounded-lg border border-gray-200 dark:border-white/[0.12] bg-white dark:bg-white/[0.06] text-gray-900 dark:text-slate-100 px-3 py-2 text-sm focus:border-gray-400 dark:focus:border-[#818cf8]/50 focus:outline-none"
                  data-rate={data.pricing.cost_per_minute}
                  data-mode="minutes"
                />
              </label>
            </div>
          )}
          <div id="est-result" class="mt-3 text-sm font-semibold text-gray-800 dark:text-slate-100 hidden">
            Estimated cost: <span id="est-value"></span>/month
          </div>
          <p class="mt-2 text-xs text-gray-400 dark:text-slate-500">Rough estimate only — verify on the pricing page before budgeting.</p>
        </div>
      )}
    </section>

    <!-- ⑧ Portability -->
    {data.portability && (
      <section id="lock-in" class="scroll-mt-24">
        <h2 class="text-lg font-semibold mb-3 text-gray-900 dark:text-white">Lock-in Risk</h2>
        <div class={`flex items-start gap-3 rounded-xl p-4 border ${data.portability.voice_model_export ? 'border-green-200 bg-green-50 dark:border-green-500/25 dark:bg-green-500/[0.08]' : 'border-orange-200 bg-orange-50 dark:border-orange-500/25 dark:bg-orange-500/[0.08]'}`}>
          <span class="text-xl shrink-0">{data.portability.voice_model_export ? '✅' : '⚠️'}</span>
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-slate-100">
              {data.portability.voice_model_export ? 'Voice model can be exported' : 'Voice model cannot be exported'}
            </div>
            {content.portabilityNotes && (
              <div class="text-xs text-gray-600 dark:text-slate-400 mt-1">{content.portabilityNotes}</div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- ⑨ Markdown body (from .md file) -->
    <section id="guide" class="prose prose-gray dark:prose-invert max-w-none scroll-mt-24">
      <Content />
    </section>

    <!-- ⑩ Alternatives -->
    {alternativeTools.length > 0 && (
      <section id="alternatives" class="scroll-mt-24">
        <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Alternatives</h2>
        <ul class="grid gap-3 sm:grid-cols-2">
          {alternativeTools.map((alt) => <ToolCard tool={alt} compact />)}
        </ul>
      </section>
    )}

    <!-- ⑪ Changelog -->
    {changelog.length > 0 && (
      <section id="changelog" class="scroll-mt-24">
        <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Recent Changes</h2>
        <ul class="divide-y divide-gray-100 dark:divide-white/[0.06]">
          {changelog.map((entry) => (
            <li class="py-3 flex items-start gap-4">
              <time class="text-xs text-gray-400 dark:text-slate-500 pt-0.5 shrink-0 w-24">{entry.date}</time>
              <div>
                <span class="text-xs px-1.5 py-0.5 rounded bg-gray-100 dark:bg-white/[0.08] text-gray-500 dark:text-slate-400">
                  {CHANGE_TYPE_LABEL[entry.change_type] ?? entry.change_type}
                </span>
                <p class="text-sm text-gray-700 dark:text-slate-300 mt-1">{changelogDescription(entry, 'en')}</p>
                {entry.source_url && (
                  <a href={entry.source_url} target="_blank" rel="noopener noreferrer"
                     class="text-xs text-blue-500 dark:text-[#818cf8] hover:underline">Source →</a>
                )}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ⑫ Giscus comments -->
    {GISCUS_ENABLED && (
      <section id="discussion" class="scroll-mt-24">
        <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Discussion</h2>
        <script
          src="https://giscus.app/client.js"
          data-repo={GISCUS.repo}
          data-repo-id={GISCUS.repoId}
          data-category={GISCUS.category}
          data-category-id={GISCUS.categoryId}
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="light"
          data-lang="en"
          crossorigin="anonymous"
          async
        ></script>
      </section>
    )}

    <!-- ⑬ Page footer -->
    <footer class="border-t border-gray-100 dark:border-white/[0.08] pt-6 flex items-center justify-between text-xs text-gray-400 dark:text-slate-500">
      <span>Last verified: {data.verified_at.toISOString().slice(0, 10)}</span>
      {editUrl && (
        <a
          href={editUrl}
          target="_blank" rel="noopener noreferrer"
          class="hover:text-gray-600 dark:hover:text-slate-300 hover:underline"
        >
          ✏️ Improve this page
        </a>
      )}
    </footer>
      </article>
    </div>
  </main>
</BaseLayout>

<script>
  // Cost estimator
  const inputs = document.querySelectorAll<HTMLInputElement>('#est-chars, #est-minutes');
  const result = document.getElementById('est-result');
  const value  = document.getElementById('est-value');

  inputs.forEach((input) => {
    input.addEventListener('input', () => {
      const qty  = parseFloat(input.value) || 0;
      const rate = parseFloat(input.dataset.rate ?? '0');
      const mode = input.dataset.mode;
      if (!result || !value) return;
      if (qty <= 0) { result.classList.add('hidden'); return; }
      const cost = mode === 'chars'
        ? (qty / 1000) * rate
        : qty * rate;
      value.textContent = `$${cost.toFixed(2)}`;
      result.classList.remove('hidden');
    });
  });
</script>
