---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import FilterPanel from '../components/FilterPanel.astro';
import { getCollection } from 'astro:content';
import { loadCategories } from '../lib/data-loader';
import { toolsByUserGroup } from '../lib/tool-helpers';

const allTools   = await getCollection('tools');
const tools      = toolsByUserGroup(allTools, 'game_devs');
const gameWorkflows = (await getCollection('workflows'))
  .filter((workflow) => workflow.data.user_group === 'game_devs')
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
const categories = loadCategories().filter((c) => c.user_group === 'game_devs' || c.user_group === 'all');
---

<BaseLayout
  title="Voice AI Tools for Game Developers"
  description="Voice AI tools for indie and AAA game developers. NPC dialogue, voice cloning, localization, sound effects, and engine integration."
>
  <main class="max-w-5xl mx-auto px-4 py-12">

    <!-- Hero -->
    <section class="mb-10 pb-8 border-b border-gray-200 dark:border-white/[0.08]">
      <div class="inline-flex items-center gap-2 text-sm font-medium px-3 py-1 rounded-full mb-4
                  text-green-700 bg-green-50 border border-green-200
                  dark:text-[#4ade80] dark:bg-[#4ade80]/10 dark:border-[#4ade80]/20">
        🎮 For Game Developers
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3 text-gray-900 dark:text-white">
        Voice AI for Game Devs
      </h1>
      <p class="text-xl max-w-2xl mb-6 text-gray-500 dark:text-slate-400">
        NPC dialogue, voice cloning, localization, and sound effects tools with clear
        commercial and in-game licensing.
      </p>
      <div class="flex flex-wrap gap-3">
        {categories.slice(0, 5).map((cat) => (
          <a href={`/category/${cat.slug}/`}
             class="text-sm px-3 py-1.5 rounded-full transition-colors
                    border border-gray-200 text-gray-600 hover:border-green-400 hover:text-green-600
                    dark:border-white/15 dark:bg-white/[0.04] dark:text-slate-300 dark:hover:border-[#4ade80]/50 dark:hover:text-[#4ade80]">
            {cat.name_en}
          </a>
        ))}
        <a href="/workflows/indie-game-voiceover/"
           class="text-sm px-3 py-1.5 rounded-full transition-colors
                  bg-green-50 text-green-700 border border-green-200 hover:bg-green-100
                  dark:bg-[#4ade80]/10 dark:text-[#4ade80] dark:border-[#4ade80]/20 dark:hover:bg-[#4ade80]/15">
          📋 Indie Game Voiceover Workflow →
        </a>
        <a href="/workflows/"
           class="text-sm px-3 py-1.5 rounded-full transition-colors
                  bg-green-50 text-green-700 border border-green-200 hover:bg-green-100
                  dark:bg-[#4ade80]/10 dark:text-[#4ade80] dark:border-[#4ade80]/20 dark:hover:bg-[#4ade80]/15">
          🎮 Game Audio Workflows →
        </a>
      </div>
    </section>

    {gameWorkflows.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-semibold mb-4 text-gray-900 dark:text-white">Game audio workflow guides</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {gameWorkflows.map((workflow) => (
            <a href={`/workflows/${workflow.slug}/`}
               class="block glass-card glass-card-gamedev rounded-xl p-4 workflow-card"
               data-bg-light="linear-gradient(135deg,rgba(34,197,94,0.08) 0%,rgba(34,197,94,0.02) 100%)"
               data-bg-dark="linear-gradient(135deg,rgba(74,222,128,0.10) 0%,rgba(74,222,128,0.03) 100%)">
              <div class="text-xs font-medium mb-2 text-green-600 dark:text-[#4ade80]">
                {workflow.data.tool_recommendations.length} tool options · {workflow.data.sources.length} sources
              </div>
              <h3 class="font-semibold text-sm mb-1 text-gray-900 dark:text-white">{workflow.data.title}</h3>
              <p class="text-xs text-gray-500 dark:text-slate-400">{workflow.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="flex gap-8">
      <FilterPanel />
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm text-gray-500 dark:text-slate-500">
            <span id="tool-count">{tools.length}</span> tools
          </p>
        </div>
        <ul class="grid gap-4 sm:grid-cols-2">
          {tools.map((tool) => <ToolCard tool={tool} />)}
        </ul>
        {tools.length === 0 && (
          <p class="text-center py-12 text-gray-400 dark:text-slate-500">
            No tools yet. <a href="/submit/" class="underline">Submit one →</a>
          </p>
        )}
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  function applyWorkflowBg() {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll<HTMLElement>('.workflow-card').forEach((card) => {
      card.style.background = isDark ? (card.dataset.bgDark ?? '') : (card.dataset.bgLight ?? '');
    });
  }
  applyWorkflowBg();
  new MutationObserver(applyWorkflowBg).observe(document.documentElement, { attributeFilter: ['class'] });
</script>
