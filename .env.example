# Copy to .env or .env.local for local update-data runs.
# Never commit real API keys.

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=

# OpenRouter Chat Completions API
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Optional metadata sent to OpenRouter.
OPENROUTER_SITE_URL=https://voice.tools
OPENROUTER_APP_NAME=Voice Tools Directory

# VoiceTools TTS backend proxy.
# Keep this server-side by default so browsers call this frontend's same-origin
# /api/voicetools/tts/* proxy instead of directly calling a private backend.
VOICETOOLS_API_ORIGIN=http://localhost:8080

# Optional shared secret sent only from the frontend proxy to the TTS backend.
# Configure the same value on the L03 backend and reject direct public requests
# that do not include a matching X-VoiceTools-Proxy-Token header.
VOICETOOLS_PROXY_TOKEN=
